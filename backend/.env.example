# Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-change-this-in-production-make-it-very-long-and-random
DEBUG=True

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# MongoDB Configuration
MONGO_URI=mongodb+srv://DL_user:Edaigrp1@dl.pmyowfm.mongodb.net/
DATABASE_NAME=dl_database

# Evaluation Mode
# local: ANN+SBERT+NLI, llama: external Llama API, auto: combined local+llama
EVALUATION_MODE=auto

# Llama Pipeline API Configuration (required for llama/auto modes)
# Example: https://your_ngrok_api.ngrok-free.app
LLAMA_API_BASE_URL=
LLAMA_TIMEOUT_SECONDS=120
LLAMA_HEALTH_PATH=/health
LLAMA_EVALUATE_PATH=/evaluate
LLAMA_BATCH_EVALUATE_PATH=/batch-evaluate
LLAMA_GENERATE_PATH=/generate-answer
LLAMA_PREFER_BATCH_EVALUATE=True
# True: Llama generates its own reference answer for Llama scoring.
# False: Llama uses teacher/model reference_answer passed from assignment data.
LLAMA_USE_GENERATED_REFERENCE=True
# Optional alias used by some notebook setups
KAGGLE_NGROK_URL=

# Groq API Configuration (Required for RAG features)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.3

# RAG Configuration
RAG_ENABLED=True
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3

# Model Paths (usually don't need to change these)
# MODEL_DIR=../Model
# SBERT_MODEL_NAME=all-MiniLM-L6-v2
# NLI_MODEL_NAME=roberta-large-mnli
